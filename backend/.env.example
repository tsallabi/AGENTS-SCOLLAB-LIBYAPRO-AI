# =============================================================
# AgentForge Configuration
# انسخ هذا الملف لـ .env وأدخل قيمك الحقيقية
# =============================================================

# --- Application ---
APP_NAME=Agents Collab + Manus
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
JWT_SECRET=another-random-secret-for-jwt-tokens
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080     # 7 أيام

# --- Server ---
HOST=0.0.0.0
PORT=8001
FRONTEND_URL=http://localhost:8001

# --- Manus Forge API (مجاني - يُضبط تلقائياً في بيئة Manus) ---
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# --- Database ---
# SQLite للتطوير المحلي (الافتراضي)
DATABASE_URL=sqlite+aiosqlite:///./agentforge_manus.db
# PostgreSQL للإنتاج (uncomment):
# DATABASE_URL=postgresql+asyncpg://agentforge:agentforge@localhost:5432/agentforge

# --- AI Providers (مفاتيح السيرفر للخطة المدفوعة) ---
# اترك فارغاً إذا لم تريد دعم نموذج معين
SERVER_ANTHROPIC_KEY=
SERVER_OPENAI_KEY=
SERVER_GEMINI_KEY=
SERVER_DEEPSEEK_KEY=

# --- Stripe (للمدفوعات) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASIC=        # ID خطة 9$/شهر
STRIPE_PRICE_ID_PRO=          # ID خطة 49$/شهر

# --- Plans Limits ---
PLAN_FREE_MESSAGES_PER_MONTH=50      # حد الخطة المجانية (بمفاتيح المستخدم)
PLAN_BASIC_MESSAGES_PER_MONTH=200    # حد الخطة الأساسية
PLAN_PRO_MESSAGES_PER_MONTH=1000     # حد الخطة الاحترافية

# --- Admin ---
ADMIN_EMAIL=admin@agentforge.com
